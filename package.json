{
  "name": "usebugreport",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.18",
  "engines": {
    "bun": ">=1.2.0 <1.3.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test:parity": "turbo run test:parity",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.51.0",
    "@types/bun": "^1.3.14",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "ultracite": "^7.0.0"
  }
}
