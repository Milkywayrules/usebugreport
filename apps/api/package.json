{
  "name": "@usebugreport/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun --watch src/index.ts",
    "test": "bun test --preload ./src/__tests__/preload.ts $(find src/__tests__ -name '*.test.ts' ! -name 'auth.integration.test.ts')",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.23",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@usebugreport/config": "workspace:*",
    "@usebugreport/contracts": "workspace:*",
    "@usebugreport/db": "workspace:*",
    "@usebugreport/queue": "workspace:*",
    "@usebugreport/services": "workspace:*",
    "@usebugreport/storage": "workspace:*",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.4.0",
    "elysia-helmet": "^3.1.0",
    "evlog": "^2.22.0",
    "openapi-types": "^12.1.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
