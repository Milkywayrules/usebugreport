# Database
DATABASE_URL=postgresql://usebugreport:usebugreport@localhost:5432/usebugreport

# Redis
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=local-dev
R2_ACCESS_KEY_ID=local-dev
R2_SECRET_ACCESS_KEY=local-dev
R2_BUCKET=usebugreport-dev

# Encryption
ENCRYPTION_KEY=local-dev-encryption-key-32chars-min

# Auth (api)
BETTER_AUTH_SECRET=local-dev-better-auth-secret-min-32-chars
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Linear integration (api)
LINEAR_CLIENT_ID=local-dev
LINEAR_CLIENT_SECRET=local-dev

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Email (worker)
RESEND_API_KEY=

# Worker
WORKER_CONCURRENCY=8
